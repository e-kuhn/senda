        if (ti) {
            EmitTypeInfo info{"VALIGN-ENUM", kore::FrozenMap<uint32_t, EmitRoleInfo>(0)};
            info.role_to_xml.freeze();
            type_to_tag.add(static_cast<uint32_t>(ti->handle), std::move(info));
        }
    }
    {
        auto* ti = tag_to_type.find("VARIABLE-ACCESS-SCOPE-ENUM");
        if (ti) {
            EmitTypeInfo info{"VARIABLE-ACCESS-SCOPE-ENUM", kore::FrozenMap<uint32_t, EmitRoleInfo>(0)};
            info.role_to_xml.freeze();
            type_to_tag.add(static_cast<uint32_t>(ti->handle), std::move(info));
        }
    }
    {
        auto* ti = tag_to_type.find("VEHICLE-DRIVER-NOTIFICATION-ENUM");
        if (ti) {
            EmitTypeInfo info{"VEHICLE-DRIVER-NOTIFICATION-ENUM", kore::FrozenMap<uint32_t, EmitRoleInfo>(0)};
            info.role_to_xml.freeze();
            type_to_tag.add(static_cast<uint32_t>(ti->handle), std::move(info));
        }
    }
    {
        auto* ti = tag_to_type.find("VERBATIM-STRING-PLAIN");
        if (ti) {
            EmitTypeInfo info{"VERBATIM-STRING-PLAIN", kore::FrozenMap<uint32_t, EmitRoleInfo>(0)};
            info.role_to_xml.freeze();
            type_to_tag.add(static_cast<uint32_t>(ti->handle), std::move(info));
        }
    }
    {
        auto* ti = tag_to_type.find("VIEW-TOKENS");
        if (ti) {
            EmitTypeInfo info{"VIEW-TOKENS", kore::FrozenMap<uint32_t, EmitRoleInfo>(0)};
            info.role_to_xml.freeze();
            type_to_tag.add(static_cast<uint32_t>(ti->handle), std::move(info));
        }
    }
    {
        auto* ti = tag_to_type.find("XML-SPACE-ENUM");
        if (ti) {
            EmitTypeInfo info{"XML-SPACE-ENUM", kore::FrozenMap<uint32_t, EmitRoleInfo>(0)};
            info.role_to_xml.freeze();
            type_to_tag.add(static_cast<uint32_t>(ti->handle), std::move(info));
        }
    }
    type_to_tag.freeze();

    return EmitLookup{std::move(type_to_tag)};
}

class ArxmlEmitter {
public:
    explicit ArxmlEmitter(const senda::domains::AutosarSchema& schema)
        : lookup_(build_emit_lookup(schema))
        , domain_fir_(schema.domain.view().fir()) {}

    bool emit(const fir::Fir& fir, std::ostream& out) {
        // Write XML header
        out << "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n";
        out << "<AUTOSAR>\n";

        // Walk FIR objects and emit XML
        emit_objects(fir, out, 1);

        out << "</AUTOSAR>\n";
        return true;
    }

    bool emit(const fir::Fir& fir, const std::filesystem::path& path) {
        std::ofstream file(path);
        if (!file) return false;
        return emit(fir, file);
    }

private:
    EmitLookup lookup_;
    const fir::Fir* domain_fir_;

    void write_indent(std::ostream& out, int indent) {
        for (int i = 0; i < indent; ++i) out << "  ";
    }

    // Resolve a TypeHandle to the domain-local index for EmitLookup keys.
    // Foreign types store their domain-local id in the ForeignRef.
    static uint32_t resolve_type_key(const fir::Fir& fir, fir::TypeHandle th) {
        if (fir::is_foreign(th)) {
            auto& ref = fir.types.foreign_type_ref(th);
            return ref.local_id;
        }
        return static_cast<uint32_t>(th);
    }

    // Resolve a RoleHandle to the domain-local index for EmitLookup keys.
    static uint32_t resolve_role_key(const fir::Fir& fir, fir::RoleHandle rh) {
        if (fir::is_foreign(rh)) {
            auto& ref = fir.types.foreign_role_ref(rh);
            return ref.local_id;
        }
        return static_cast<uint32_t>(rh);
    }

    // Find a role's EmitRoleInfo by walking the supertype chain in the domain FIR.
    // Roles like SHORT-NAME are defined on Referrable but inherited by subtypes.
    const EmitRoleInfo* find_role_in_hierarchy(const fir::Fir& compile_fir,
                                                fir::TypeHandle th,
                                                uint32_t role_key) {
        if (!domain_fir_) return nullptr;
        // Resolve compile FIR's type handle to a domain-local type index
        uint32_t local_idx = resolve_type_key(compile_fir, th);
        auto local_th = fir::TypeHandle{local_idx};

        for (int depth = 0; depth < 20; ++depth) {
            if (fir::is_none(local_th)) break;
            auto idx = static_cast<uint32_t>(local_th);
            if (idx >= domain_fir_->types.types.size()) break;
            // Walk to supertype
            auto super = domain_fir_->types.types[idx].supertype;
            if (fir::is_none(super)) break;
            local_th = super;
            // Check this supertype's roles in the EmitLookup
            auto* ti = lookup_.type_to_tag.find(static_cast<uint32_t>(local_th));
            if (ti) {
                auto* info = ti->role_to_xml.find(role_key);
                if (info) return info;
            }
        }
        return nullptr;
    }

    void emit_node(const fir::Fir& fir, fir::NodeHandle nh,
                   std::ostream& out, int indent) {
        auto& node = fir.model.node(nh);

        // Look up type -> XML tag (resolve foreign type to domain-local index)
        auto* type_info = lookup_.type_to_tag.find(resolve_type_key(fir, node.type));
        if (!type_info) return;  // Unknown type, skip

        // Write opening tag
        write_indent(out, indent);
        out << "<" << type_info->xml_tag << ">\n";

        // Write properties
        auto props = fir.model.props_of(node);
        for (auto& prop : props) {
            auto role_key = resolve_role_key(fir, prop.role());
            auto* role_info = type_info->role_to_xml.find(role_key);
            // Fall back to supertype chain for inherited roles (e.g. SHORT-NAME)
            if (!role_info) role_info = find_role_in_hierarchy(fir, node.type, role_key);
            if (!role_info) continue;

            if (prop.is_node()) {
                // Nested object — recurse
                emit_node(fir, prop.node_handle(), out, indent + 1);
            } else {
                auto vh = prop.value_handle();
                write_indent(out, indent + 1);
                out << "<" << role_info->xml_element << ">";
                switch (fir::value_kind(vh)) {
                case fir::ValueKind::String:
                    out << fir.get_string(fir.model.values.get_string(vh));
                    break;
                case fir::ValueKind::Integer:
                    out << fir.model.values.get_integer(vh).as_int64();
                    break;
                case fir::ValueKind::Float:
                    out << fir.model.values.get_float(vh);
                    break;
                case fir::ValueKind::Boolean:
                    out << (fir.model.values.get_boolean(vh) ? "true" : "false");
                    break;
                default:
                    break;
                }
                out << "</" << role_info->xml_element << ">\n";
            }
        }

        // Write closing tag
        write_indent(out, indent);
        out << "</" << type_info->xml_tag << ">\n";
    }

    void emit_objects(const fir::Fir& fir, std::ostream& out, int indent) {
        // Emit only top-level objects (those with no parent)
        for (uint32_t i = 0; i < fir.model.nodes.size(); ++i) {
            auto nh = fir::NodeHandle{i};
            auto& node = fir.model.node(nh);
            if (fir::is_none(node.parent)) {
                emit_node(fir, nh, out, indent);
            }
        }
    }
};

}  // namespace senda
